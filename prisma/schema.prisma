generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model EgpProject {
  id                     String   @id @db.VarChar(191)
  projectNumber          String?  @db.VarChar(191)
  title                  String   @db.VarChar(512)
  methodId               String?  @db.VarChar(191)
  centralPriceBaht       Decimal? @db.Decimal(15, 2)
  winnerName             String?  @db.VarChar(512)
  winnerAmountBaht       Decimal? @db.Decimal(15, 2)
  bidDate                DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  announcements EgpAnnouncement[]

  @@index([projectNumber])
  @@index([title])
}

model EgpAnnouncement {
  id             String   @id @db.VarChar(191)
  announceType   String   @db.VarChar(191)
  rawDescription String   @db.Text
  link           String   @db.VarChar(512)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectId String
  project   EgpProject @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([announceType])
  @@index([publishedAt])
}