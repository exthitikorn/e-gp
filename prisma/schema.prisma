generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// หน่วยงาน (รหัสหน่วยงานภาครัฐ / หน่วยจัดซื้อย่อย ตามคู่มือ RSS e-GP)
model EgpAgency {
  id   String @id @default(cuid()) @db.VarChar(191)
  name String @db.VarChar(512)
  /// รหัสหน่วยงานภาครัฐ (`deptId`) รองรับหลายค่า โดยคั่นด้วย comma
  deptId String? @db.Text
  /// รหัสหน่วยจัดซื้อย่อย (`deptsubId`) รองรับหลายค่า โดยคั่นด้วย comma
  deptsubId String? @db.Text
  /// 0 = ไม่ใช้งาน, 1 = ใช้งาน (รวมใน ingest)
  status Int @default(1) @db.TinyInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects      EgpProject[]
  announcements EgpAnnouncement[]
}

model EgpProject {
  id                     String   @id @default(cuid()) @db.VarChar(191)
  projectNumber          String   @db.VarChar(191)
  title                  String   @db.VarChar(512)
  methodId               String?  @db.VarChar(191)
  centralPriceBaht       Decimal? @db.Decimal(15, 2)
  winnerName             String?  @db.VarChar(512)
  winnerAmountBaht       Decimal? @db.Decimal(15, 2)
  bidDate                DateTime?
  status                 String?  @db.VarChar(191)
  cancelDate             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  agencyId String    @db.VarChar(191)
  agency   EgpAgency @relation(fields: [agencyId], references: [id], onDelete: Restrict)

  announcements EgpAnnouncement[]

  @@unique([agencyId, projectNumber])
  @@index([agencyId])
  @@index([title])
}

model EgpAnnouncement {
  id             String   @id @db.VarChar(191)
  announceType   String   @db.VarChar(191)
  rawDescription String   @db.Text
  link           String   @db.VarChar(512)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectId String     @db.VarChar(191)
  project   EgpProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  agencyId String    @db.VarChar(191)
  agency   EgpAgency @relation(fields: [agencyId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([agencyId])
  @@index([announceType])
  @@index([publishedAt])
}
